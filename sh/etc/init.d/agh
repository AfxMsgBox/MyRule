#!/bin/sh /etc/rc.common
# AdGuardHome 的 procd 服务

# OpenWrt rc.common 约定的启停优先级
START=99
STOP=1
USE_PROCD=1

# AGH 二进制路径与工作目录
PROG=/usr/bin/AdGuardHome
WORK_DIR=/etc/proxy/agh

start_service() {
    # 让 procd 接管进程
    procd_open_instance
    # 主命令：AdGuardHome -c <conf> -w <workdir> --no-check-update
    procd_set_param command "$PROG" -c "$WORK_DIR/agh.yaml" -w "$WORK_DIR" --no-check-update
    # 1 小时窗口内崩 5 次后停止重启
    procd_set_param respawn 3600 5 5
    # stdout / stderr 走 logread
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

# 让 procd 默认 SIGTERM 收尾，避免 killall 误伤
stop_service() { return 0; }

# reload 等价于完整重启
reload_service() { stop; start; }
