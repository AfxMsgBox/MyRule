#!/bin/sh /etc/rc.common
# 启动代理内核（mihomo 或同协议替代品）的 procd 服务。
# MP_CORE_BIN 由 /etc/proxy/sh/env.conf 决定，换内核只改一处。

# OpenWrt rc.common 约定的启停优先级
START=98
STOP=2
USE_PROCD=1

# env.conf 是硬性依赖
[ -f /etc/proxy/sh/env.conf ] || { logger -t MyProxy "缺少 /etc/proxy/sh/env.conf"; exit 1; }
# 加载全局变量
# shellcheck disable=SC1091
. /etc/proxy/sh/env.conf
# 本地覆盖（可选）
# shellcheck disable=SC1091
[ -f /etc/proxy/sh/env.local.conf ] && . /etc/proxy/sh/env.local.conf

start_service() {
    # 二进制不存在或不可执行时记录后退出
    [ -x "$MP_CORE_BIN" ] || { logger -t "$MP_LOG_TAG" "代理内核不存在或不可执行：$MP_CORE_BIN"; return 1; }
    # 让 procd 接管进程
    procd_open_instance
    # 主命令：mihomo -d <work-dir>
    procd_set_param command "$MP_CORE_BIN" -d "$MP_CORE_DIR"
    # 1 小时窗口内崩 5 次后停止重启，避免崩溃循环拖死设备
    procd_set_param respawn 3600 5 5
    # stdout / stderr 走 logread
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

# 让 procd 默认 SIGTERM 收尾，避免 killall 误伤
stop_service() { return 0; }

# reload 等价于完整重启
reload_service() { stop; start; }
