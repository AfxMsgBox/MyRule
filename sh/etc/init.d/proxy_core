#!/bin/sh /etc/rc.common
# 启动代理内核（mihomo 或同协议替代品）的 procd 服务。
# 内核可执行路径由 /etc/proxy/sh/env.conf 中的 CORE_BIN 决定，换内核只需改一处。

START=98
STOP=2
USE_PROCD=1

# shellcheck disable=SC1091
[ -f /etc/proxy/sh/env.conf ] && . /etc/proxy/sh/env.conf
CORE_DIR="${CORE_DIR:-/etc/proxy/core}"
CORE_BIN="${CORE_BIN:-$CORE_DIR/mihomo}"
LOG_TAG="${LOG_TAG:-MyRule}"

start_service() {
    if [ ! -x "$CORE_BIN" ]; then
        logger -t "$LOG_TAG" "代理内核可执行文件不存在或不可执行：$CORE_BIN"
        return 1
    fi
    procd_open_instance
    procd_set_param command "$CORE_BIN" -d "$CORE_DIR"
    # 1 小时窗口内崩溃 5 次后停止重启，避免崩溃循环拖死设备
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    # 交给 procd 默认逻辑用 SIGTERM 收尾，避免 killall 误伤
    return 0
}

reload_service() {
    stop
    start
}
